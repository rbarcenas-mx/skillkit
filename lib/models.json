{
  "config": {
    "mode": "low",
    "fallback_chain": ["medium", "high", "low"],
    "config_file": "~/.config/skillkit/config.json"
  },
  "providers": {
    "ollama": {
      "base_url": "http://localhost:11434/v1",
      "api_key": ""
    },
    "deepseek": {
      "base_url": "https://api.deepseek.com/v1",
      "api_key": "{env:DEEPSEEK_API_KEY}"
    },
    "opencode-go": {
      "base_url": "https://opencode.ai/zen/go/v1",
      "api_key": "{env:OPENCODE_API_KEY}"
    },
    "anthropic": {
      "base_url": "https://api.anthropic.com/v1",
      "api_key": "{env:ANTHROPIC_API_KEY}"
    }
  },
  "models": [
    {
      "id": "deepseek-r1:32b",
      "provider": "ollama",
      "description": "Deep reasoning, good for planning, audit and QA plan generation",
      "speed": "slow",
      "token_cost": 0
    },
    {
      "id": "deepseek-coder-v2:16b",
      "provider": "ollama",
      "description": "Code generation and technical review",
      "speed": "medium",
      "token_cost": 0
    },
    {
      "id": "gemma4:26b",
      "provider": "ollama",
      "description": "General multilingual model, good for varied tasks",
      "speed": "medium",
      "token_cost": 0
    },
    {
      "id": "gemma4:audit",
      "provider": "ollama",
      "description": "Lightweight Gemma 4 for audits and quick reviews",
      "speed": "fast",
      "token_cost": 0
    },
    {
      "id": "deepseek-v4-flash",
      "provider": "deepseek",
      "description": "Fast DeepSeek model, good cost-quality for general tasks",
      "speed": "fast",
      "token_cost": "low"
    },
    {
      "id": "deepseek-v4-pro",
      "provider": "deepseek",
      "description": "Premium DeepSeek model, deep reasoning for complex tasks",
      "speed": "medium",
      "token_cost": "low"
    },
    {
      "id": "opencode-go/deepseek-v4-flash",
      "provider": "opencode-go",
      "api_model": "deepseek-v4-flash",
      "description": "DeepSeek V4 Flash via opencode-go",
      "speed": "fast",
      "token_cost": "low"
    },
    {
      "id": "opencode-go/deepseek-v4-pro",
      "provider": "opencode-go",
      "api_model": "deepseek-v4-pro",
      "description": "DeepSeek V4 Pro via opencode-go",
      "speed": "medium",
      "token_cost": "low"
    },
    {
      "id": "opencode-go/kimi-k2.7-code",
      "provider": "opencode-go",
      "api_model": "kimi-k2.7-code",
      "description": "Kimi K2.7 Code via opencode-go, code-specialized",
      "speed": "medium",
      "token_cost": "medium"
    },
    {
      "id": "opencode-go/glm-5.2",
      "provider": "opencode-go",
      "api_model": "glm-5.2",
      "description": "GLM 5.2 via opencode-go, multilingual with strong reasoning",
      "speed": "medium",
      "token_cost": "high"
    },
    {
      "id": "opencode-go/mimo-v2.5",
      "provider": "opencode-go",
      "api_model": "mimo-v2.5",
      "description": "MiMo V2.5 via opencode-go, ultra-fast and economical",
      "speed": "fast",
      "token_cost": "low"
    },
    {
      "id": "opencode-go/mimo-v2.5-pro",
      "provider": "opencode-go",
      "api_model": "mimo-v2.5-pro",
      "description": "MiMo V2.5 Pro via opencode-go, premium with better quality",
      "speed": "medium",
      "token_cost": "medium"
    },
    {
      "id": "opencode-go/qwen3.7-max",
      "provider": "opencode-go",
      "api_model": "qwen3.7-max",
      "description": "Qwen 3.7 Max via opencode-go, maximum quality",
      "speed": "medium",
      "token_cost": "high"
    },
    {
      "id": "opencode-go/qwen3.7-plus",
      "provider": "opencode-go",
      "api_model": "qwen3.7-plus",
      "description": "Qwen 3.7 Plus via opencode-go, balanced cost-quality",
      "speed": "fast",
      "token_cost": "low"
    }
  ],
  "skill_mapping": {
    "prespec": {
      "task": "Idea analysis, ambiguity detection",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/glm-5.2"
    },
    "ci.prepare": {
      "task": "Planning and classification for CI integration",
      "low": "deepseek-r1:32b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/glm-5.2"
    },
    "qa.prepare": {
      "task": "QA validation plan generation",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-pro",
      "high": "opencode-go/glm-5.2"
    },
    "audit.spec_plan_tasks": {
      "task": "Audit of specifications, plans and tasks",
      "low": "gemma4:audit",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/glm-5.2"
    },
    "audit.codigo": {
      "task": "Code audit against specification",
      "low": "deepseek-coder-v2:16b",
      "medium": "opencode-go/kimi-k2.7-code",
      "high": "opencode-go/kimi-k2.7-code"
    },
    "pr-review": {
      "task": "Pull Request review (blast radius, security, breaking changes)",
      "low": "deepseek-coder-v2:16b",
      "medium": "opencode-go/kimi-k2.7-code",
      "high": "opencode-go/kimi-k2.7-code"
    },
    "audit.resolve_spec": {
      "task": "Finding resolution in spec, plan and tasks",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/deepseek-v4-pro"
    },
    "audit.resolve_codigo": {
      "task": "Finding resolution in code",
      "low": "deepseek-coder-v2:16b",
      "medium": "opencode-go/kimi-k2.7-code",
      "high": "opencode-go/kimi-k2.7-code"
    },
    "audit.lint": {
      "task": "Linting and typecheck audit (ESLint, tsc --noEmit)",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/deepseek-v4-pro"
    },
    "diagrams": {
      "task": "Mermaid.js diagram generation",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/deepseek-v4-pro"
    },
    "qa.execute": {
      "task": "Failure diagnosis during QA execution",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/deepseek-v4-pro"
    },
    "ci.execute": {
      "task": "CI task execution coordination (local commits, rollback, dependencies)",
      "low": "gemma4:audit",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/glm-5.2"
    },
    "ci.ship": {
      "task": "Pre-push validation, review coordination, push and CI monitoring",
      "low": "gemma4:26b",
      "medium": "opencode-go/deepseek-v4-flash",
      "high": "opencode-go/glm-5.2"
    }
  }
}
